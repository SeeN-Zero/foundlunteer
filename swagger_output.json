{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Foundlunteer API",
    "description": "API documentation synchronized with current Express 5 routes."
  },
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "tags": [
    {
      "name": "User",
      "description": "Registration, authentication, account profile and file retrieval"
    },
    {
      "name": "Individual",
      "description": "Individual profile management, job save/register and document upload"
    },
    {
      "name": "Organization",
      "description": "Organization profile management and registrant handling"
    },
    {
      "name": "Job",
      "description": "Job posting and lifecycle management"
    }
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT Bearer token in format: Bearer <token>"
    }
  },
  "paths": {
    "/user/add": {
      "post": {
        "tags": ["User"],
        "summary": "Register a new account",
        "description": "Creates a new user with role individual or organization.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UserRegisterRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["User"],
        "summary": "Login with email and password",
        "description": "Returns JWT token and profile context for authenticated user.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UserLoginRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/LoginResponse" }
          }
        }
      }
    },
    "/user/get": {
      "get": {
        "tags": ["User"],
        "summary": "Get current user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/user/image": {
      "post": {
        "tags": ["User"],
        "summary": "Upload user avatar image",
        "description": "Multipart upload for profile image file.",
        "security": [{ "bearerAuth": [] }],
        "consumes": ["multipart/form-data"],
        "parameters": [
          {
            "in": "formData",
            "name": "image",
            "type": "file",
            "required": true,
            "description": "Image file"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/user/getimage": {
      "get": {
        "tags": ["User"],
        "summary": "Get own avatar image",
        "security": [{ "bearerAuth": [] }],
        "produces": ["image/png"],
        "responses": {
          "200": { "description": "PNG image stream" },
          "404": { "description": "Image not found" }
        }
      }
    },
    "/user/getimage/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "Get avatar image by user ID (authenticated)",
        "security": [{ "bearerAuth": [] }],
        "produces": ["image/png"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "PNG image stream" },
          "404": { "description": "Image not found" }
        }
      }
    },
    "/user/getimageuser/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "Public-style avatar fetch with token query",
        "description": "Requires valid JWT in query parameter token and returns image file.",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "token",
            "in": "query",
            "required": true,
            "type": "string",
            "description": "JWT token used by validateJwt middleware"
          }
        ],
        "produces": ["image/png"],
        "responses": {
          "200": { "description": "PNG image stream" },
          "400": { "description": "Missing userId" },
          "404": { "description": "Image not found" }
        }
      }
    },
    "/user/getcv": {
      "get": {
        "tags": ["User"],
        "summary": "Download own CV",
        "security": [{ "bearerAuth": [] }],
        "produces": ["application/pdf"],
        "responses": {
          "200": { "description": "PDF file stream" },
          "404": { "description": "CV not found" }
        }
      }
    },
    "/user/getcv/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "Download CV by user ID with authorization check",
        "security": [{ "bearerAuth": [] }],
        "produces": ["application/pdf"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "PDF file stream" },
          "404": { "description": "CV not found" }
        }
      }
    },
    "/user/getijazah": {
      "get": {
        "tags": ["User"],
        "summary": "Download own ijazah",
        "security": [{ "bearerAuth": [] }],
        "produces": ["application/pdf"],
        "responses": {
          "200": { "description": "PDF file stream" },
          "404": { "description": "Ijazah not found" }
        }
      }
    },
    "/user/getijazah/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "Download ijazah by user ID with authorization check",
        "security": [{ "bearerAuth": [] }],
        "produces": ["application/pdf"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "PDF file stream" },
          "404": { "description": "Ijazah not found" }
        }
      }
    },
    "/user/getsertifikat": {
      "get": {
        "tags": ["User"],
        "summary": "Download own sertifikat",
        "security": [{ "bearerAuth": [] }],
        "produces": ["application/pdf"],
        "responses": {
          "200": { "description": "PDF file stream" },
          "404": { "description": "Sertifikat not found" }
        }
      }
    },
    "/user/getsertifikat/{userId}": {
      "get": {
        "tags": ["User"],
        "summary": "Download sertifikat by user ID with authorization check",
        "security": [{ "bearerAuth": [] }],
        "produces": ["application/pdf"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "PDF file stream" },
          "404": { "description": "Sertifikat not found" }
        }
      }
    },
    "/user/changepassword": {
      "post": {
        "tags": ["User"],
        "summary": "Change password for logged-in user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/ChangePasswordRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/user/sendcode": {
      "post": {
        "tags": ["User"],
        "summary": "Send forgot-password verification code",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/SendCodeRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/user/forgotpassword": {
      "post": {
        "tags": ["User"],
        "summary": "Reset password with email + code",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/ForgotPasswordRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/individual/update": {
      "post": {
        "tags": ["Individual"],
        "summary": "Update individual profile",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UpdateIndividualRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/individual/saveordeletejob/{jobId}": {
      "post": {
        "tags": ["Individual"],
        "summary": "Toggle save or unsave a job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Success toggle result" }
        }
      }
    },
    "/individual/savedjob": {
      "get": {
        "tags": ["Individual"],
        "summary": "Get saved jobs for current individual",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/individual/registeredjob": {
      "get": {
        "tags": ["Individual"],
        "summary": "Get jobs where current individual is registered",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/individual/register/{jobId}": {
      "post": {
        "tags": ["Individual"],
        "summary": "Register current individual to a job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/individual/file": {
      "post": {
        "tags": ["Individual"],
        "summary": "Upload CV, ijazah and sertifikat files",
        "security": [{ "bearerAuth": [] }],
        "consumes": ["multipart/form-data"],
        "parameters": [
          {
            "name": "cv",
            "in": "formData",
            "type": "file",
            "required": false
          },
          {
            "name": "ijazah",
            "in": "formData",
            "type": "file",
            "required": false
          },
          {
            "name": "sertifikat",
            "in": "formData",
            "type": "file",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/individual/filestatus": {
      "get": {
        "tags": ["Individual"],
        "summary": "Get upload status of individual files",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/organization/getjob": {
      "get": {
        "tags": ["Organization"],
        "summary": "Get all jobs created by current organization",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/organization/update": {
      "post": {
        "tags": ["Organization"],
        "summary": "Update organization profile",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UpdateOrganizationRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/organization/jobdetail/{jobId}": {
      "get": {
        "tags": ["Organization"],
        "summary": "Get job detail and registrants for an organization job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/organization/updateregistrant": {
      "post": {
        "tags": ["Organization"],
        "summary": "Update registrant status for a job application",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UpdateRegistrantStatusRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/job/add": {
      "post": {
        "tags": ["Job"],
        "summary": "Create new job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/AddJobRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/job/getAll": {
      "get": {
        "tags": ["Job"],
        "summary": "Get job list with optional query filters",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "jobStatus",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": ["OPEN", "CLOSE"]
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/job/get/{jobId}": {
      "get": {
        "tags": ["Job"],
        "summary": "Get a job by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/job/update/{jobId}": {
      "post": {
        "tags": ["Job"],
        "summary": "Update a job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UpdateJobRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/job/updatestatus/{jobId}": {
      "post": {
        "tags": ["Job"],
        "summary": "Update only job status",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/UpdateJobStatusRequest" }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    },
    "/job/delete/{jobId}": {
      "post": {
        "tags": ["Job"],
        "summary": "Soft delete / remove a job by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": { "$ref": "#/definitions/MessageResponse" }
          }
        }
      }
    }
  },
  "definitions": {
    "MessageResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "success"
        }
      }
    },
    "LoginResponse": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        },
        "id": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["INDIVIDUAL", "ORGANIZATION"]
        }
      }
    },
    "UserRegisterRequest": {
      "type": "object",
      "required": ["email", "password", "name", "address", "phone", "role"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "password": {
          "type": "string",
          "minLength": 7
        },
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 64
        },
        "address": {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        },
        "phone": {
          "type": "string",
          "pattern": "^\\d+$",
          "minLength": 10,
          "maxLength": 12
        },
        "role": {
          "type": "string",
          "enum": ["individual", "organization"]
        }
      }
    },
    "UserLoginRequest": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "password": {
          "type": "string",
          "minLength": 7
        }
      }
    },
    "SendCodeRequest": {
      "type": "object",
      "required": ["email"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        }
      }
    },
    "ForgotPasswordRequest": {
      "type": "object",
      "required": ["email", "code", "password"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "code": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 9999
        },
        "password": {
          "type": "string",
          "minLength": 7
        }
      }
    },
    "ChangePasswordRequest": {
      "type": "object",
      "required": ["password"],
      "properties": {
        "password": {
          "type": "string",
          "minLength": 7
        }
      }
    },
    "UpdateIndividualRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 32
        },
        "address": {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        },
        "phone": {
          "type": "string",
          "pattern": "^\\d+$",
          "minLength": 10,
          "maxLength": 12
        },
        "birthOfDate": {
          "type": "string",
          "format": "date-time"
        },
        "description": {
          "type": "string"
        },
        "social": {
          "type": "string"
        }
      }
    },
    "UpdateOrganizationRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 64
        },
        "address": {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        },
        "phone": {
          "type": "string",
          "pattern": "^\\d+$",
          "minLength": 10,
          "maxLength": 12
        },
        "leader": {
          "type": "string",
          "minLength": 3,
          "maxLength": 32
        },
        "description": {
          "type": "string"
        },
        "social": {
          "type": "string"
        }
      }
    },
    "UpdateRegistrantStatusRequest": {
      "type": "object",
      "required": ["individualId", "jobId", "registrantStatus"],
      "properties": {
        "individualId": {
          "type": "string"
        },
        "jobId": {
          "type": "string"
        },
        "registrantStatus": {
          "type": "string",
          "enum": ["ONPROCESS", "REJECTED", "ACCEPTED"]
        }
      }
    },
    "AddJobRequest": {
      "type": "object",
      "required": ["title", "description", "location", "expiredAt"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5
        },
        "description": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "expiredAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "UpdateJobRequest": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5
        },
        "description": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "expiredAt": {
          "type": "string",
          "format": "date-time"
        },
        "jobStatus": {
          "type": "string",
          "enum": ["OPEN", "CLOSE"]
        }
      }
    },
    "UpdateJobStatusRequest": {
      "type": "object",
      "required": ["jobStatus"],
      "properties": {
        "jobStatus": {
          "type": "string",
          "enum": ["OPEN", "CLOSE"]
        }
      }
    }
  }
}
